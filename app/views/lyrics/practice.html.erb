<div style="margin-top: 3rem; padding: 2rem; font-family: 'Inter', sans-serif; background-color: #f8f8f8; border-radius: 0.75rem; box-shadow: 0 0.5rem 1rem rgba(0, 0, 0, 0.05);">
  <div style="padding-bottom: 2rem; border-bottom: 1px solid #e2e8f0;">
    <h1 style="font-size: 2.5rem; font-weight: 700; color: #2d3748; margin-bottom: 1rem;"><%= @song.title %></h1>
    <p style="font-size: 1.1rem; color: #718096; margin-bottom: 1.5rem;">by <%= @song.artist %></p>

    <% if @song.song_art_image_url.present? %>
      <div style="margin-bottom: 2rem; border-radius: 0.5rem; overflow: hidden; box-shadow: 0 0.25rem 0.5rem rgba(0, 0, 0, 0.03);">
        <%= image_tag @song.song_art_image_url, alt: @song.title, style: "width: 100%; max-height: 350px; object-fit: cover; display: block;" %>
      </div>
    <% else %>
      <div style="margin-bottom: 2rem; background-color: #edf2f7; border-radius: 0.5rem; display: flex; align-items: center; justify-content: center; height: 15rem;">
        <span style="color: #a0aec0; font-size: 1rem;">No Image Available</span>
      </div>
    <% end %>
  </div>

  <div style="padding-top: 2rem; line-height: 1.7; color: #4a5568; white-space: pre-wrap;">
    <% if @song.lyrics_html.present? %>
      <%= raw @song.lyrics_html %>
    <% else %>
      <p style="color: #e53e3e;"><%= flash[:alert] %></p>
    <% end %>
  </div>

  <%= link_to 'Back to Search', search_lyrics_path, style: "display: inline-block; margin-top: 2rem; background-color: #cbd5e0; color: #4a5568; font-weight: 500; padding: 0.75rem 1.5rem; border-radius: 0.375rem; text-decoration: none; transition: background-color 0.2s ease-in-out; &:hover { background-color: #a0aec0; }" %>
</div>
