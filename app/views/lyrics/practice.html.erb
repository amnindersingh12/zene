<h1>Practice Typing</h1>

<h2><%= @song.title %> by <%= @song.artist %></h2>

<div class="lyrics-container">
  <pre id="lyrics"><%= @song.lyrics %></pre>
</div>

<textarea id="typing-area" placeholder="Start typing here..." autofocus></textarea>

<div id="feedback"></div>

<% if false %> <button id="reset-button">Reset</button>
  <script>
    document.getElementById('reset-button')?.addEventListener('click', () => {
      typingArea.value = '';
      feedbackElement.textContent = '';
      lyricsElement.innerHTML = originalLyrics.split('').map(char => `<span class="untyped">${char}</span>`).join('');
      typingArea.disabled = false;
    });
  </script>
<% end %>

<script>
  const lyricsElement = document.getElementById('lyrics');
  const typingArea = document.getElementById('typing-area');
  const feedbackElement = document.getElementById('feedback');
  const originalLyrics = lyricsElement.textContent;
  let typedText = '';
  let currentIndex = 0;

  // Initialize the lyrics with untyped spans
  lyricsElement.innerHTML = originalLyrics.split('').map(char => `<span class="untyped">${char}</span>`).join('');

  typingArea.addEventListener('input', () => {
    typedText = typingArea.value;
    feedbackElement.innerHTML = '';
    let feedbackHTML = '';
    let correct = true;

    for (let i = 0; i < originalLyrics.length; i++) {
      const expectedChar = originalLyrics[i];
      const typedChar = typedText[i];

      if (typedChar === undefined) {
        feedbackHTML += `<span class="untyped">${expectedChar}</span>`;
      } else if (typedChar === expectedChar) {
        feedbackHTML += `<span class="correct">${typedChar}</span>`;
      } else {
        feedbackHTML += `<span class="incorrect">${expectedChar}</span>`;
        correct = false;
      }
    }

    lyricsElement.innerHTML = feedbackHTML;

    if (typedText === originalLyrics) {
      feedbackElement.textContent = 'Congratulations! You typed it correctly!';
      typingArea.disabled = true;
    } else if (typedText.length > originalLyrics.length) {
      feedbackElement.textContent = 'Oops! You typed extra characters.';
    }
  });
</script>

<style>
  .lyrics-container {
    background-color: #f8f8f8;
    padding: 20px;
    border: 1px solid #eee;
    border-radius: 5px;
    white-space: pre-wrap; /* Preserve line breaks */
    font-family: monospace;
    font-size: 1.1em;
    margin-bottom: 15px;
  }

  #typing-area {
    width: 100%;
    padding: 12px; /* Slightly increased padding */
    margin-bottom: 10px;
    border: 2px solid #337ab7; /* More prominent border */
    border-radius: 5px;
    font-size: 1.1em;
    font-family: monospace;
    box-shadow: 1px 1px 3px #ccc inset; /* Subtle focus */
  }

  #typing-area:focus {
    outline: none; /* Remove default focus outline */
    border-color: #286090; /* Darker border on focus */
  }

  #feedback {
    font-weight: bold;
    margin-top: 10px;
  }

  .correct {
    color: green;
  }

  .incorrect {
    color: red;
    text-decoration: underline;
  }

  .untyped {
    color: #333;
  }

  #reset-button {
    padding: 8px 15px;
    background-color: #f44336;
    color: white;
    border: none;
    border-radius: 5px;
    cursor: pointer;
    font-size: 1em;
    margin-top: 10px;
  }

  #reset-button:hover {
    background-color: #d32f2f;
  }
</style>
