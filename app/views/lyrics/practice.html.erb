<div style="margin-top: 3rem; padding: 2.5rem; font-family: 'Figtree', sans-serif; background-color: #f0fdfa; border-radius: 1rem; box-shadow: 0 0.75rem 1.5rem rgba(0, 0, 0, 0.07);">
  <div style="padding-bottom: 2.5rem; border-bottom: 1px solid #d1fae5;">
    <h1 style="font-size: 3rem; font-weight: 800; color: #064e3b; margin-bottom: 0.75rem;"><%= @song.title %></h1>
    <p style="font-size: 1.125rem; color: #34d399; margin-bottom: 1.75rem;">by the one and only: <%= @song.artist %></p>

    <% if @song.song_art_image_url.present? %>
      <div style="margin-bottom: 2.25rem; border-radius: 0.75rem; overflow: hidden; box-shadow: 0 0.3rem 0.6rem rgba(0, 0, 0, 0.04);">
        <%= image_tag @song.song_art_image_url, alt: "#{@song.title} album art - feast your eyes!" %>
      </div>
    <% else %>
      <div style="margin-bottom: 2.25rem; background-color: #ccfbf6; border-radius: 0.75rem; display: flex; align-items: center; justify-content: center; height: 16rem; border: 2px dashed #86efac;">
        <span style="color: #a7f3d0; font-size: 1.1rem; font-style: italic;">🎶 Sadly, no album art to judge. Moving on... 🎶</span>
      </div>
    <% end %>
  </div>
 <% if @song.lyrics_html.present? %>
  <div style="margin-top: 2rem; padding: 1.5rem; font-family: 'Poppins', sans-serif; background-color: #f9f5ff; border-radius: 0.5rem; box-shadow: 0 0.25rem 0.5rem rgba(0, 0, 0, 0.03); color: #52426a; line-height: 1.6; white-space: pre-wrap; font-size: 1rem;">
  <h2 style="font-size: 1.5rem; font-weight: 600; color: #6d28d9; margin-bottom: 1rem;">Lyrics:</h2>
  <%= raw @song.lyrics_html %>
</div>
<% else %>

      <p style="color: #f43f5e; font-weight: bold;"><%= flash[:alert] || "Uh oh! Looks like the lyrics went on a vacation. 🏖️" %></p>
      <p style="color: #f43f5e;">Maybe try hitting that search button again? Just a thought! 😉</p>
    <% end %>
  </div>

  <%= link_to 'Back to the Lyric-Hunting Grounds', search_lyrics_path, style: "display: inline-block; margin-top: 2.5rem; background-color: #a7f3d0; color: #065f46; font-weight: 600; padding: 0.8rem 1.75rem; border-radius: 0.5rem; text-decoration: none; transition: background-color 0.2s ease-in-out; &:hover { background-color: #6ee7b7; }" %>
</div>

<style>
  /* Modern Font - Figtree (you might need to include this in your CSS) */
  @import url('https://fonts.googleapis.com/css2?family=Poppins:wght@400;500&display=swap');

  @import url('https://fonts.googleapis.com/css2?family=Figtree:wght@400;500;600;700;800&display=swap');
</style>
