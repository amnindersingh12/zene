<div style="margin-top: 2rem; padding: 1.5rem; font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; background-color: #f9f7f6;">
  <h1 style="font-size: 2.2rem; font-weight: 600; color: #333; margin-bottom: 1.5rem;">Popular Tracks</h1>
  <% if @popular_songs.present? %>
    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 1.5rem;">
      <% @popular_songs.each do |song| %>
        <div style="background-color: #fff; border-radius: 0.5rem; box-shadow: 0 0.25rem 0.5rem rgba(0, 0, 0, 0.1); overflow: hidden;">
          <% if song.song_art_image_url.present? %>
            <%= image_tag song.song_art_image_url, alt: song.title, style: "width: 100%; height: 12rem; object-fit: cover; display: block;" %>
          <% else %>
            <div style="width: 100%; height: 12rem; background-color: #eee; display: flex; align-items: center; justify-content: center;">
              <span style="color: #777; font-size: 0.9rem;">No Image</span>
            </div>
          <% end %>
          <div style="padding: 1rem;">
            <h2 style="font-size: 1.1rem; font-weight: 500; color: #444; margin-bottom: 0.5rem;"><%= song.title %></h2>
            <p style="color: #666; font-size: 0.85rem; margin-bottom: 0.5rem;">by <%= song.artist %></p>
            <div style="display: flex; justify-content: space-between; align-items: center;">
              <span style="color: #888; font-size: 0.75rem;">Pyongs: <%= song.pyongs_count %></span>
              <%= link_to 'Practice', practice_lyric_path(song), style: "display: inline-block; background-color: #6366f1; color: #fff; font-weight: 500; padding: 0.5rem 1rem; border-radius: 1.5rem; font-size: 0.8rem; text-decoration: none; transition: background-color 0.2s ease-in-out; &:hover { background-color: #4f46e5; }" %>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <p style="color: #666;">No popular songs available.</p>
  <% end %>
</div>

<div style="margin-top: 1.5rem; padding: 1.5rem; font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;">
  <%= form_with(url: search_lyrics_path, method: :get, style: "display: flex; align-items: center;") do |form| %>
    <%= form.text_field :query, placeholder: "Search for lyrics...", style: "box-shadow: 0 0.1rem 0.2rem rgba(0, 0, 0, 0.05); border: 1px solid #ddd; border-radius: 0.25rem; padding: 0.6rem 0.8rem; font-size: 0.9rem; color: #333; width: 100%; outline: none; transition: border-color 0.2s ease-in-out; &:focus { border-color: #6366f1; }" %>
    <%= form.button "Search", style: "background-color: #3b82f6; color: #fff; font-weight: 500; padding: 0.6rem 1rem; border-radius: 0.25rem; font-size: 0.9rem; text-decoration: none; margin-left: 0.5rem; border: none; cursor: pointer; transition: background-color 0.2s ease-in-out; &:hover { background-color: #2563eb; }" %>
  <% end %>

  <% if @search_results.present? %>
    <h2 style="font-size: 1.1rem; font-weight: 500; color: #333; margin-top: 1.5rem; margin-bottom: 0.75rem;">Search Results</h2>
    <ul style="list-style-type: disc; padding-left: 1.2rem; color: #555;">
      <% @search_results.each do |result| %>
        <li style="margin-bottom: 0.5rem;"><%= link_to result.title, practice_lyric_path(result), style: "color: #6366f1; text-decoration: none; font-weight: 400; transition: color 0.2s ease-in-out; &:hover { color: #4f46e5; }" %> - <%= result.artist %></li>
      <% end %>
    </ul>
  <% elsif params[:query].present? %>
    <p style="color: #666; margin-top: 0.75rem;">No results found for '<%= params[:query] %>'.</p>
  <% end %>
</div>
