<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= yield(:title) || "#{Rails.application.class.module_parent_name} - Serving You Earworms & Good Times!" %></title>
  <%= csrf_meta_tags %>
  <%= csp_meta_tag %>

  <%= stylesheet_link_tag 'application', media: 'all', 'data-turbolinks-track': 'reload' %>
  <%= javascript_include_tag 'application', 'data-turbolinks-track': 'reload' %>

  <% if @song&.song_art_image_url.present? %>
    <meta property="og:image" content="<%= @song.song_art_image_url %>">
  <% end %>

  <%= yield(:head) %>

  <style>
    /* Modern Font - Inter (you might need to include this in your CSS or via link tag) */
    @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;600;800&display=swap');

    body {
      font-family: 'Inter', sans-serif;
      background-color: #f4f5f7; /* Light, modern background */
      color: #333; /* Darker, readable text */
      margin: 0;
      padding: 0;
      min-height: 100vh;
      display: flex;
      flex-direction: column;
    }

    header {
      background-color: #fff; /* Clean header background */
      padding: 1.5rem 2rem;
      box-shadow: 0 0.125rem 0.25rem rgba(0, 0, 0, 0.08); /* Subtle shadow */
      display: flex;
      align-items: center;
      justify-content: space-between; /* Space out title and image */
    }

    header h1 {
      font-size: 1.75rem;
      font-weight: 800;
      color: #2c3e50; /* Darker title color */
      margin: 0;
    }

    header h1 a {
      text-decoration: none;
      color: inherit;
    }

    header img {
      max-width: 60px; /* Slightly smaller image */
      height: auto;
      border-radius: 0.375rem; /* Softly rounded image */
      box-shadow: 0 0.1rem 0.2rem rgba(0, 0, 0, 0.06);
    }

    .container {
      padding: 2rem;
      flex-grow: 1; /* Allow container to take up remaining vertical space */
    }

    /* Add more modern UI styles for your specific content within .container */
  </style>
</head>
<body>
  <header>
    <h1><%= link_to "Zene - Your Personal Sound Alchemist", root_path %></h1>
    <% if @song&.song_art_image_url.present? %>
      <%= image_tag @song.song_art_image_url, alt: "#{@song.title} Album Art (Pretty Swanky, Right?)", style: "max-width: 60px; height: auto; border-radius: 0.375rem; box-shadow: 0 0.1rem 0.2rem rgba(0, 0, 0, 0.06);" %>
    <% else %>
      <span style="font-size: 0.8rem; color: #777; font-style: italic;">No album art to show off... yet!</span>
    <% end %>
  </header>

  <div class="container">
    <%= yield %>
    <% if flash[:notice] %>
      <div class="alert alert-success" role="alert" style="background-color: #d1e7dd; color: #0f5132; padding: 1rem; border-radius: 0.375rem; margin-top: 1rem;">
        <%= flash[:notice] %>
      </div>
    <% end %>
    <% if flash[:alert] %>
      <div class="alert alert-danger" role="alert" style="background-color: #f8d7da; color: #842029; padding: 1rem; border-radius: 0.375rem; margin-top: 1rem;">
        <%= flash[:alert] %>
      </div>
    <% end %>
  </div>

  <footer style="background-color: #f8f9fa; padding: 1rem 2rem; text-align: center; color: #6c757d; font-size: 0.9rem; margin-top: 2rem; border-top: 1px solid #dee2e6;">
    &copy; <%= Time.now.year %> Zene - Where the Beats Drop (and Sometimes the Lyrics Too!)
  </footer>
</body>
</html>
